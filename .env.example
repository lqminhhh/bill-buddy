# Copy this file to .env and fill in real values. .env is gitignored.

# JWT signing key. REQUIRED in production. In dev a placeholder is used.
# Generate with: python -c 'import secrets; print(secrets.token_hex(32))'
JWT_SECRET_KEY=replace-with-output-of-python-secrets-token_hex-32

# FastAPI database. Defaults to local SQLite at ./bill_buddy.db when unset.
# For Neon, paste the connection string from the Neon dashboard and replace
# the `postgresql://` scheme with `postgresql+psycopg://`.
# DATABASE_URL=postgresql+psycopg://USER:PASSWORD@HOST/DBNAME?sslmode=require

# Comma-separated allowed CORS origins for the React frontend.
# Default is localhost dev. For prod, add your Vercel URL.
# ALLOWED_ORIGINS=https://bill-buddy.vercel.app,http://localhost:5173
